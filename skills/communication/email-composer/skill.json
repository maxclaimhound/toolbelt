{
  "id": "email-composer",
  "name": "Email Composer",
  "version": "1.0.0",
  "description": "Compose a professional email given recipient, subject, and key points. No API key required.",
  "author": "AgentSkills",
  "license": "MIT",
  "tier": "free",
  "frameworks": ["google-ai-edge", "lmstudio", "ollama", "generic"],
  "requirements": {},
  "input": {
    "type": "object",
    "properties": {
      "recipient": { "type": "string" },
      "subject": { "type": "string" },
      "points": { "description": "Key points or single paragraph" },
      "tone": { "type": "string", "enum": ["professional", "friendly", "formal", "brief"] },
      "senderName": { "type": "string" }
    },
    "required": ["recipient", "points"]
  },
  "output": {
    "type": "object",
    "properties": {
      "subject": { "type": "string" },
      "body": { "type": "string" },
      "recipient": { "type": "string" },
      "characterCount": { "type": "number" },
      "wordCount": { "type": "number" }
    }
  },
  "ui": { "renderer": "markdown" },
  "tags": ["email", "communication", "compose", "writing"]
}
